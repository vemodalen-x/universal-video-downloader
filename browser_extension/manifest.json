{
  "manifest_version": 3,
  "name": "Universal Video Downloader Companion",
  "version": "1.2.0",
  "description": "Detect public media on the active tab and send a selected URL to the Windows desktop client.",
  "key": "",
  "permissions": [
    "activeTab",
    "scripting",
    "nativeMessaging"
  ],
  "icons": {
    "16": "icon.png",
    "32": "icon.png",
    "48": "icon.png",
    "64": "icon.png"
  },
  "action": {
    "default_title": "检测当前页面媒体",
    "default_icon": {
      "16": "icon.png",
      "32": "icon.png",
      "48": "icon.png"
    },
    "default_popup": "popup.html"
  }
}
